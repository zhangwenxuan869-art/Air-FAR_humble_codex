Panels:
  - Class: rviz_common/Displays
    Name: Displays
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Enabled: true
      Name: Grid
      Plane: XY
      Reference Frame: map
      Value: true
    - Class: rviz_default_plugins/TF
      Enabled: true
      Name: TF
      Value: true
    - Class: rviz_default_plugins/PointCloud2
      Enabled: true
      Name: TerrainCloud
      Topic:
        Value: /terrain_cloud
      Value: true
    - Class: rviz_default_plugins/PointCloud2
      Enabled: true
      Name: ScanCloud
      Topic:
        Value: /scan_cloud
      Value: true
    - Class: rviz_default_plugins/PointCloud2
      Enabled: true
      Name: NewObstacles
      Topic:
        Value: /new_PCL
      Value: true
    - Class: rviz_default_plugins/PointCloud2
      Enabled: true
      Name: DynamicObstacles
      Topic:
        Value: /DP_dynamic_obs_debug
      Value: true
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Path
      Topic:
        Value: /viz_path_topic
      Value: true
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Nodes
      Topic:
        Value: /viz_node_topic
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Graph
      Topic:
        Value: /viz_graph_topic
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Contours
      Topic:
        Value: /viz_contour_topic
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: MapGrids
      Topic:
        Value: /viz_grid_map_topic
      Value: true
  Enabled: true
  Global Options:
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/SetGoal
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 35
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Name: Current View
      Pitch: 0.6
      Yaw: 0.8
Window Geometry:
  Height: 900
  Width: 1400
